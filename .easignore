# EAS Build archive rules
# EAS uses this file instead of .gitignore when present.
# assets/videos/ is intentionally NOT excluded — video files needed at build time.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
.claude/

# Data room (large markdown corpus — not needed at build time)
kanext-dataroom-intelligence/

# Player pool pipeline (not needed at build time)
services/player-pool/
