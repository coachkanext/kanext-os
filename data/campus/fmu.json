    "mission": "The mission of Florida Memorial University is to instill in students the importance of becoming global citizens through life-long learning, leadership, character, and service, which will enhance their lives and the lives of others.",
    "vision": "As South Florida's HBCU (Historically Black College and University), Florida Memorial University will be a premiere urban-serving liberal arts educational institution preparing the next generation of global leaders.",
    "values": {
      "acronym": "CLASS",
      "items": [
        { "letter": "C", "name": "Character", "description": "Embodying the values of fairness, transparency, compassion, respect, integrity, honesty, respect for diversity, and a commitment to equality in everything we undertake." },
        { "letter": "L", "name": "Leadership", "description": "Cultivating the drive to initiate and sustain change for the good of our campus, our community, and the world." },
        { "letter": "A", "name": "Accountability", "description": "Taking responsibility for our actions, collectively as well as individually, and delivering products and services that are of high-caliber and responsive to the needs of our community members." },
        { "letter": "S", "name": "Scholarship", "description": "Promoting excellence in teaching and learning through the identification and retention of quality faculty, staff, and students, who are all engaged in vigorous intellectual exchange as a part of high-quality and competitive educational programs." },
        { "letter": "S", "name": "Service", "description": "Sharing our academic and human capital as social, educational, and economic resources for the betterment of our campus and our community." }
      ]
    },
    "history": {
      "founded_as": "Florida Baptist Institute",
      "founded_location": "Live Oak, Florida",
      "founded_by": "Members of the Bethlehem Baptist Association",
      "timeline": [
        { "year": 1879, "event": "Founded as Florida Baptist Institute in Live Oak, FL" },
        { "year": 1892, "event": "Rev. Matthew Gilbert fled racial tensions to Jacksonville, founded Florida Baptist Academy" },
        { "year": 1896, "event": "Nathan White Collier appointed president, held post for 45 years" },
        { "year": 1900, "event": "J. Rosamond Johnson composed music for 'Lift Ev'ry Voice and Sing' while teaching at the school" },
        { "year": 1918, "event": "Relocated to St. Augustine as Florida Normal and Industrial Institute" },
        { "year": 1942, "event": "Merged with Florida Institute at Live Oak, became Florida Normal Industrial and Memorial College" },
        { "year": 1965, "event": "Trustees purchased 48-acre former air strip near Opa-locka in Dade County" },
        { "year": 1968, "event": "New campus opened as Florida Memorial College on November 11" },
        { "year": 2004, "event": "Charter amended, name changed to Florida Memorial University" }
      ],
      "notable_connections": [
        "J. Rosamond Johnson — composed 'Lift Ev'ry Voice and Sing' (Negro National Anthem) while employed here",
        "Zora Neale Hurston — Harlem Renaissance writer, served as instructor",
        "Rev. Dr. Martin Luther King Jr. — orchestrated civil rights protests involving FMU students",
        "Harry T. Moore — civil rights advocate and NAACP leader, graduate",
        "Rev. Howard Thurman — renowned American theologian, graduate"
      ]
    }
